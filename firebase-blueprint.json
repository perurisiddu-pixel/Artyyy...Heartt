{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A handmade painting or artwork",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier" },
        "title": { "type": "string", "description": "Name of the artwork" },
        "description": { "type": "string", "description": "Detailed story of the piece" },
        "price": { "type": "number", "description": "Price in USD" },
        "image": { "type": "string", "description": "URL to the artwork image" },
        "category": { "type": "string", "description": "Art style or category" },
        "size": { "type": "string", "description": "Dimensions of the canvas" },
        "isFeatured": { "type": "boolean", "description": "Whether to show in featured section" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "price", "image", "category"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Customer feedback and reviews",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "text": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "text", "rating"]
    },
    "CartItem": {
      "title": "CartItem",
      "description": "An item in a user's shopping cart",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "quantity": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["productId", "quantity", "userId"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order for artworks",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["COD", "UPI"] },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "customerName", "address", "phone", "paymentMethod", "items", "total"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Global collection of available artworks"
    },
    "/testimonials/{testimonialId}": {
      "schema": "Testimonial",
      "description": "Customer reviews"
    },
    "/users/{userId}/cart/{cartItemId}": {
      "schema": "CartItem",
      "description": "User-specific shopping cart items"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    }
  }
}
