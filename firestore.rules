rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: products
    // Fields: title (str), description (str), price (num), image (url), category (str), size (str), isFeatured (bool)
    //
    // Collection: testimonials
    // Fields: name (str), text (str), rating (num)
    //
    // Collection: users/{userId}/cart
    // Fields: productId (str), quantity (num), userId (str)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         (request.auth.token.email == "perurisiddu@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProduct(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.image is string && data.image.size() > 0 &&
             data.category is string && data.category.size() > 0;
    }

    // Products: Publicly readable, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(request.resource.data);
    }

    // Testimonials: Publicly readable, authenticated users can create
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                    request.resource.data.name is string && 
                    request.resource.data.text is string && 
                    request.resource.data.rating is number;
      allow update, delete: if isAdmin();
    }

    // User Cart: Only owner can read/write
    match /users/{userId}/cart/{cartItemId} {
      allow read, write: if isOwner(userId);
    }

    // Orders: Users can create their own, admins can read all
    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // User Profile: Only owner can read/write, admin can manage roles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && 
                    (request.resource.data.role == 'user' || 
                     (request.resource.data.role == 'admin' && request.auth.token.email == "perurisiddu@gmail.com"));
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
    }
  }
}
